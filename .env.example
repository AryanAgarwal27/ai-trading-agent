# ───────────────────────────────────────────────────────────────
# ai-trading-agent — example environment file
# Copy to `.env` and fill in. `.env` is gitignored. Never commit.
# Single source of truth for project conventions: BRD.md + SPEC.md.
# ───────────────────────────────────────────────────────────────

# ───────────── Postgres (single cluster, three logical DBs per BRD §5.8) ─────────────
# The compose file boots a single postgres:15 with pgvector enabled and creates
# the three databases at init time. SCRAM-SHA-256 auth (BRD §15).
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=trading_agent
POSTGRES_PASSWORD=change_me_local_only
# Override the host port if 5432 is already taken on this machine
# (e.g. another local project). Container port is always 5432.
# POSTGRES_HOST_PORT=5433
# REDIS_HOST_PORT=6380
# App DB connection string (used by Alembic + FastAPI)
DATABASE_URL=postgresql+psycopg://trading_agent:change_me_local_only@127.0.0.1:5432/app
# LangGraph checkpointer connection (BRD §1.1 rule 6: Postgres from day one)
LANGGRAPH_CHECKPOINT_URI=postgresql://trading_agent:change_me_local_only@127.0.0.1:5432/langgraph_checkpoints
# LangGraph long-term Store (BRD §5.9 namespaces)
LANGGRAPH_STORE_URI=postgresql://trading_agent:change_me_local_only@127.0.0.1:5432/langgraph_store

# ───────────── Redis (APScheduler jobstore + pubsub) ─────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ───────────── LangGraph hardening (BRD §6.6) ─────────────
# Enforces strict msgpack deserialization to prevent code execution
# from a compromised checkpoint database. Always true in any env.
LANGGRAPH_STRICT_MSGPACK=true

# ───────────── Anthropic (LLM) ─────────────
ANTHROPIC_API_KEY=

# ───────────── LangSmith tracing (SPEC §1 Q4) ─────────────
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=ai-trading-agent
LANGSMITH_API_KEY=

# ───────────── Backups (SPEC §3.1) ─────────────
# Placeholder for Stage 0. The actual rclone remote is created by the operator
# in Stage 10; ops/backup.sh will use `rclone copy ... gdrive:<path>/`.
BACKUP_TARGET=gdrive_rclone
# BACKUP_RCLONE_REMOTE=gdrive:ai-trading-agent-backups     # Stage 10
# BACKUP_RCLONE_CONFIG=/home/aryan/.config/rclone/rclone.conf  # Stage 10

# ───────────── Exchange API keys (Stage 7+ paper, Stage 8+ live) ─────────────
# SPEC §1 Q1: Binance. Per BRD §1.1 rule 5, paper and live MUST use SEPARATE
# subaccount keys; the live subaccount MUST have withdrawals disabled at the
# exchange and an IP allowlist set (BRD §15).
# EXCHANGE_NAME=binance
# BINANCE_PAPER_API_KEY=
# BINANCE_PAPER_API_SECRET=
# BINANCE_LIVE_API_KEY=
# BINANCE_LIVE_API_SECRET=

# ───────────── Live capital cap (SPEC §1 Q3) ─────────────
# Enforced via Freqtrade `stake_amount` and reflected in
# orchestrator/gates/thresholds.py LIVE_CAPITAL_CAP_USD.
LIVE_CAPITAL_CAP_USD=500

# ───────────── FastAPI / dashboard binds (BRD §15: 127.0.0.1 only) ─────────────
ORCHESTRATOR_HOST=127.0.0.1
ORCHESTRATOR_PORT=8000
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8501
